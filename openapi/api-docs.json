{
  "openapi": "3.0.0",
  "info": {
    "title": "Translation Service API",
    "version": "1.0.0",
    "description": "API for authenticated translation CRUD, search, tagging, and locale export. For local Swagger testing, seed the demo user, then log in with jane@example.com / secret123 or authorize with bearer token local-demo-api-token."
  },
  "servers": [
    {
      "url": "/",
      "description": "Application server"
    }
  ],
  "paths": {
    "/api/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new API user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterPayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered user and token"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Issue an API token",
        "description": "For local Swagger testing, seed the demo user first: php artisan db:seed --class=DemoUserSeeder. Demo credentials: jane@example.com / secret123.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated token"
          },
          "422": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/user": {
      "get": {
        "tags": ["Auth"],
        "summary": "Fetch the current user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Revoke the current token",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Token revoked"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/translations": {
      "get": {
        "tags": ["Translations"],
        "summary": "Search translations",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "locale",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Tag name or slug. Multiple tags can be comma-separated.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100,
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated translations"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      },
      "post": {
        "tags": ["Translations"],
        "summary": "Create or upsert a translation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslationPayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created translation"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/translations/{translation}": {
      "get": {
        "tags": ["Translations"],
        "summary": "Show one translation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TranslationId"
          }
        ],
        "responses": {
          "200": {
            "description": "Translation"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "tags": ["Translations"],
        "summary": "Update a translation",
        "description": "Partially update a translation. If key or locale is changed, the resulting key/locale pair must be unique.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TranslationId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslationUpdatePayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated translation"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "delete": {
        "tags": ["Translations"],
        "summary": "Delete a translation",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TranslationId"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted translation"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/translations/export/{locale}": {
      "get": {
        "tags": ["Export"],
        "summary": "Export flat translations for a locale",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "locale",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "en"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flat translation payload"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API token"
      }
    },
    "parameters": {
      "TranslationId": {
        "name": "translation",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "example": 1
        }
      }
    },
    "schemas": {
      "RegisterPayload": {
        "type": "object",
        "required": ["name", "email", "password", "password_confirmation"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Jane Translator"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          },
          "password_confirmation": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          }
        }
      },
      "LoginPayload": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "jane@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "secret123"
          }
        }
      },
      "TranslationPayload": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/TranslationByKeyLocalePayload"
          },
          {
            "$ref": "#/components/schemas/TranslationByIdsPayload"
          }
        ],
        "description": "Create or upsert a translation. Use either key/locale or translation_key_id/locale_id, not both."
      },
      "TranslationByKeyLocalePayload": {
        "type": "object",
        "required": ["key", "locale", "value"],
        "properties": {
          "key": {
            "type": "string",
            "example": "auth.login.title"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Login page title"
          },
          "locale": {
            "type": "string",
            "example": "en"
          },
          "locale_name": {
            "type": "string",
            "example": "English"
          },
          "value": {
            "type": "string",
            "example": "Log in"
          },
          "is_reviewed": {
            "type": "boolean",
            "example": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["web", "auth"]
          }
        }
      },
      "TranslationByIdsPayload": {
        "type": "object",
        "required": ["translation_key_id", "locale_id", "value"],
        "properties": {
          "translation_key_id": {
            "type": "integer",
            "example": 1
          },
          "locale_id": {
            "type": "integer",
            "example": 1
          },
          "value": {
            "type": "string",
            "example": "Log in"
          },
          "is_reviewed": {
            "type": "boolean",
            "example": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["web", "auth"]
          }
        }
      },
      "TranslationUpdatePayload": {
        "type": "object",
        "description": "Partial update payload. Send only the fields that should change. Use either key or translation_key_id, and either locale or locale_id. The resulting key/locale pair must not already exist on another translation.",
        "properties": {
          "key": {
            "type": "string",
            "example": "auth.login.title"
          },
          "translation_key_id": {
            "type": "integer",
            "example": 1
          },
          "locale": {
            "type": "string",
            "example": "en"
          },
          "locale_id": {
            "type": "integer",
            "example": 1
          },
          "value": {
            "type": "string",
            "example": "Sign in"
          },
          "is_reviewed": {
            "type": "boolean",
            "example": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["web", "auth", "release"]
          }
        }
      }
    }
  }
}
